# Database (PostgreSQL — Supabase)
# Transaction pooler URL (used by Next.js serverless functions)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection URL (used by Prisma migrations)
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_ISSUER="reihen"
JWT_AUDIENCE="reihen-users"

# Clerk Auth (optional hybrid mode)
# Keep empty to use the built-in demo auth only.
# When set, Clerk login/sign-up/password reset are available and API auth falls back to Clerk sessions.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Optional local/standalone Socket.IO server. Leave empty on Vercel if using Supabase Realtime.
NEXT_PUBLIC_WS_URL=""
WS_PORT=3001

# Supabase Realtime (recommended for Vercel)
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Firebase Realtime Database (optional live mirror)
# Use this as a realtime accelerator, not as the primary relational database.
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_DATABASE_URL=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
# Server-side Admin SDK credentials. Paste raw JSON or base64 encoded JSON.
FIREBASE_DATABASE_URL=""
FIREBASE_SERVICE_ACCOUNT_JSON=""

# Web Push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@reihen.mn"

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
# Set to "true" when behind a reverse proxy (nginx, cloudflare, etc.)
TRUSTED_PROXY=false

# Upstash Redis (optional, recommended for rate limiting and API response cache)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Payment / SMS mode — "mock" for demo, "live" for production
PAYMENT_MODE=mock
SMS_MODE=mock

# Live-mode provider credentials (only used when *_MODE=live)
QPAY_MERCHANT_ID=""
QPAY_CLIENT_ID=""
QPAY_CLIENT_SECRET=""
SMS_API_URL=""
SMS_API_KEY=""
SMS_SENDER="Reihen"

# Cron
ENABLE_CRON=true

# AI Chatbot (Groq — free)
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=""

# Locale
DEFAULT_LOCALE="mn"
TZ="Asia/Ulaanbaatar"
