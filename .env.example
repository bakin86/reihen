# Database (MariaDB)
DATABASE_URL="mysql://root:password@localhost:3306/reihen"

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_ISSUER="reihen"
JWT_AUDIENCE="reihen-users"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WS_URL="http://localhost:3001"
WS_PORT=3001

# Web Push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@reihen.mn"

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
# Set to "true" when behind a reverse proxy (nginx, cloudflare, etc.)
TRUSTED_PROXY=false

# Payment / SMS mode — "mock" for demo, "live" for production
PAYMENT_MODE=mock
SMS_MODE=mock

# Live-mode provider credentials (only used when *_MODE=live)
QPAY_MERCHANT_ID=""
QPAY_CLIENT_ID=""
QPAY_CLIENT_SECRET=""
SMS_API_URL=""
SMS_API_KEY=""
SMS_SENDER="Reihen"

# Cron
ENABLE_CRON=true

# AI Chatbot (Groq — free)
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=""

# Locale
DEFAULT_LOCALE="mn"
TZ="Asia/Ulaanbaatar"
